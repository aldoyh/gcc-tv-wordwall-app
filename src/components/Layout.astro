---
export interface Props {
  title?: string;
}

const { title = 'WordYard' } = Astro.props;
import Notification from './Notification.astro';
import { t, getLanguage } from '../utils/i18n';

const currentLang = getLanguage();
---

<!doctype html>
<html lang={currentLang} dir={currentLang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles/globals.css">
  </head>
  <body class="app-shell">
    <nav class="top-nav">
      <div class="top-nav-links">
        <a href="/" class="top-nav-link">{t('app_title')}</a>
        <a href="/leaderboard" class="top-nav-link">{t('leaderboard')}</a>
        <a href="/create" class="top-nav-link">{t('create_new_game')}</a>
      </div>
      <div class="language-switcher">
        <select id="language-select" class="language-select" aria-label={t('language')}>
          <option value="en">English</option>
          <option value="ar">العربية</option>
        </select>
      </div>
    </nav>
    <main class="page-content">
      <slot />
    </main>
    <Notification />
    <script>
      import '../scripts/language-switcher.ts';
    </script>
  </body>
</html>