---
import Layout from "../components/Layout.astro";
import { t } from '../utils/i18n';
---

<Layout title={t('app_title')}>
  <section class="panel hero">
    <h1 class="hero-title">{t('app_title')}</h1>
    <p class="hero-subtitle">{t('home_subtitle')}</p>
    <p class="hero-subtitle">{t('home_description')}</p>
    <div class="hero-actions">
      <a href="/create" class="btn-primary cta-link">
        {t('create_new_game')}
      </a>
      <a href="/leaderboard" class="btn-secondary cta-link">
        {t('view_leaderboard')}
      </a>
    </div>
  </section>
</Layout>